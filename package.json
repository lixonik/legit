{
  "name": "jegit",
  "displayName": "JeGit – JetBrains-style Git",
  "description": "JetBrains-style Git workflow for VS Code: changelists, shelve, rich commit, log graph.",
  "version": "0.1.0",
  "publisher": "lixonik",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lixonik/jegit.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "JeGit",
      "properties": {
        "jegit.log.maxCount": {
          "type": "number",
          "default": 400,
          "description": "Maximum number of commits to load in the Log tab."
        },
        "jegit.panel.autoReveal": {
          "type": "boolean",
          "default": true,
          "description": "Reveal the jegit panel automatically when a git repository opens."
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "jegitPanel",
          "title": "JeGit",
          "icon": "media/jegit.svg"
        }
      ]
    },
    "views": {
      "jegitPanel": [
        {
          "id": "jegit.versionControl",
          "name": "Version Control",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "jegit.refresh",
        "title": "Refresh",
        "category": "JeGit",
        "icon": "$(refresh)"
      },
      {
        "command": "jegit.newChangelist",
        "title": "New Changelist...",
        "category": "JeGit",
        "icon": "$(add)"
      },
      {
        "command": "jegit.focus",
        "title": "Show Version Control",
        "category": "JeGit"
      },
      {
        "command": "jegit.branches",
        "title": "Branches...",
        "category": "JeGit",
        "icon": "$(git-branch)"
      },
      {
        "command": "jegit.update",
        "title": "Update Project (Pull)",
        "category": "JeGit",
        "icon": "$(sync)"
      },
      {
        "command": "jegit.push",
        "title": "Push...",
        "category": "JeGit",
        "icon": "$(repo-push)"
      },
      {
        "command": "jegit.toggleBlame",
        "title": "Annotate with Git Blame",
        "category": "JeGit",
        "icon": "$(git-commit)"
      },
      {
        "command": "jegit.fileHistory",
        "title": "Show File History",
        "category": "JeGit",
        "icon": "$(history)"
      },
      {
        "command": "jegit.newTag",
        "title": "New Tag...",
        "category": "JeGit",
        "icon": "$(tag)"
      },
      {
        "command": "jegit.applyPatch",
        "title": "Apply Patch...",
        "category": "JeGit",
        "icon": "$(diff)"
      },
      {
        "command": "jegit.stash",
        "title": "Stash Changes...",
        "category": "JeGit",
        "icon": "$(archive)"
      },
      {
        "command": "jegit.unstash",
        "title": "Unstash...",
        "category": "JeGit",
        "icon": "$(archive)"
      }
    ],
    "keybindings": [
      {
        "command": "jegit.focus",
        "key": "alt+9"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jegit.branches",
          "when": "view == jegit.versionControl",
          "group": "navigation@1"
        },
        {
          "command": "jegit.newChangelist",
          "when": "view == jegit.versionControl",
          "group": "navigation@2"
        },
        {
          "command": "jegit.refresh",
          "when": "view == jegit.versionControl",
          "group": "navigation@3"
        },
        {
          "command": "jegit.update",
          "when": "view == jegit.versionControl",
          "group": "navigation@4"
        },
        {
          "command": "jegit.push",
          "when": "view == jegit.versionControl",
          "group": "navigation@5"
        }
      ],
      "editor/context": [
        {
          "command": "jegit.toggleBlame",
          "when": "resourceScheme == file",
          "group": "navigation@9"
        },
        {
          "command": "jegit.fileHistory",
          "when": "resourceScheme == file",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/codicons": "^0.0.45",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}

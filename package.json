{
  "name": "jegit",
  "displayName": "JeGit – JetBrains-style Git",
  "description": "JetBrains-style Git workflow for VS Code: changelists, shelve, rich commit, log graph.",
  "version": "0.1.0",
  "publisher": "lixonik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lixonik/jegit.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "JeGit",
      "properties": {
        "jegit.log.maxCount": {
          "type": "number",
          "default": 400,
          "description": "Maximum number of commits to load in the Log tab."
        },
        "jegit.panel.autoReveal": {
          "type": "boolean",
          "default": true,
          "description": "Reveal the JeGit panel automatically when a git repository opens."
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "jegitPanel",
          "title": "JeGit",
          "icon": "media/jegit.svg"
        }
      ]
    },
    "views": {
      "jegitPanel": [
        {
          "id": "jegit.versionControl",
          "name": "Version Control",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "jegit.refresh",
        "title": "Refresh",
        "category": "JeGit",
        "icon": "$(refresh)"
      },
      {
        "command": "jegit.newChangelist",
        "title": "New Changelist...",
        "category": "JeGit",
        "icon": "$(add)"
      },
      {
        "command": "jegit.focus",
        "title": "Show Version Control",
        "category": "JeGit"
      },
      {
        "command": "jegit.branches",
        "title": "Branches...",
        "category": "JeGit",
        "icon": "$(git-branch)"
      },
      {
        "command": "jegit.manageRemotes",
        "title": "Manage Remotes...",
        "category": "JeGit",
        "icon": "$(cloud)"
      },
      {
        "command": "jegit.update",
        "title": "Update Project (Pull)",
        "category": "JeGit",
        "icon": "$(sync)"
      },
      {
        "command": "jegit.push",
        "title": "Push...",
        "category": "JeGit",
        "icon": "$(repo-push)"
      },
      {
        "command": "jegit.pushForce",
        "title": "Force Push",
        "category": "JeGit",
        "icon": "$(repo-force-push)"
      },
      {
        "command": "jegit.pushTags",
        "title": "Push Tags",
        "category": "JeGit",
        "icon": "$(tag)"
      },
      {
        "command": "jegit.toggleBlame",
        "title": "Annotate with Git Blame",
        "category": "JeGit",
        "icon": "$(git-commit)"
      },
      {
        "command": "jegit.fileHistory",
        "title": "Show File History",
        "category": "JeGit",
        "icon": "$(history)"
      },
      {
        "command": "jegit.compareFileWithBranch",
        "title": "Compare File with Branch...",
        "category": "JeGit",
        "icon": "$(git-compare)"
      },
      {
        "command": "jegit.openFileOnRemote",
        "title": "Open File on Remote",
        "category": "JeGit",
        "icon": "$(globe)"
      },
      {
        "command": "jegit.newTag",
        "title": "New Tag...",
        "category": "JeGit",
        "icon": "$(tag)"
      },
      {
        "command": "jegit.applyPatch",
        "title": "Apply Patch...",
        "category": "JeGit",
        "icon": "$(diff)"
      },
      {
        "command": "jegit.applyPatchClipboard",
        "title": "Apply Patch from Clipboard",
        "category": "JeGit",
        "icon": "$(diff)"
      },
      {
        "command": "jegit.fetch",
        "title": "Fetch",
        "category": "JeGit",
        "icon": "$(sync)"
      },
      {
        "command": "jegit.continueOperation",
        "title": "Continue Merge/Rebase/Cherry-Pick",
        "category": "JeGit",
        "icon": "$(debug-continue)"
      },
      {
        "command": "jegit.abortOperation",
        "title": "Abort Merge/Rebase/Cherry-Pick",
        "category": "JeGit",
        "icon": "$(stop)"
      },
      {
        "command": "jegit.skipCommit",
        "title": "Skip Commit (Rebase)",
        "category": "JeGit",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "jegit.cleanupBranches",
        "title": "Clean Up Merged Branches...",
        "category": "JeGit",
        "icon": "$(trash)"
      },
      {
        "command": "jegit.browseAtRevision",
        "title": "Browse Repository at Revision...",
        "category": "JeGit",
        "icon": "$(history)"
      },
      {
        "command": "jegit.worktrees",
        "title": "Worktrees...",
        "category": "JeGit",
        "icon": "$(repo)"
      },
      {
        "command": "jegit.stash",
        "title": "Stash Changes...",
        "category": "JeGit",
        "icon": "$(archive)"
      },
      {
        "command": "jegit.unstash",
        "title": "Unstash...",
        "category": "JeGit",
        "icon": "$(archive)"
      }
    ],
    "keybindings": [
      {
        "command": "jegit.focus",
        "key": "alt+9"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jegit.branches",
          "when": "view == jegit.versionControl",
          "group": "navigation@1"
        },
        {
          "command": "jegit.newChangelist",
          "when": "view == jegit.versionControl",
          "group": "navigation@2"
        },
        {
          "command": "jegit.refresh",
          "when": "view == jegit.versionControl",
          "group": "navigation@3"
        },
        {
          "command": "jegit.update",
          "when": "view == jegit.versionControl",
          "group": "navigation@4"
        },
        {
          "command": "jegit.push",
          "when": "view == jegit.versionControl",
          "group": "navigation@5"
        }
      ],
      "editor/context": [
        {
          "command": "jegit.toggleBlame",
          "when": "resourceScheme == file",
          "group": "navigation@9"
        },
        {
          "command": "jegit.fileHistory",
          "when": "resourceScheme == file",
          "group": "navigation@10"
        },
        {
          "command": "jegit.compareFileWithBranch",
          "when": "resourceScheme == file",
          "group": "navigation@11"
        },
        {
          "command": "jegit.openFileOnRemote",
          "when": "resourceScheme == file",
          "group": "navigation@12"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "python -m http.server 8099"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/codicons": "^0.0.45",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
